{
  "name": "@forge/khix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "build": "NODE_ENV=production pnpm with-env next build --webpack",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev --port 3007",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "NODE_ENV=production pnpm with-env next start --port 3007",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@forge/api": "workspace:*",
    "@gsap/react": "^2.1.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@trpc/client": "catalog:",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "next": "^16.2.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@forge/eslint-config": "workspace:*",
    "@forge/prettier-config": "workspace:*",
    "@forge/tailwind-config": "workspace:*",
    "@forge/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@forge/prettier-config"
}

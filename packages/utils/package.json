{
  "name": "@forge/utils",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./discord": "./src/discord.ts",
    "./forms": "./src/forms.ts",
    "./forms.client": "./src/forms.client.ts",
    "./google": "./src/google.ts",

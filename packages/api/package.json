{
  "name": "@forge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env.ts"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./src/utils.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.0",
    "@forge/auth": "workspace:*",
    "@forge/consts": "workspace:*",
    "@forge/db": "workspace:*",
    "@forge/email": "workspace:^",
    "@forge/validators": "workspace:*",
    "@stripe/stripe-js": "^5.10.0",
    "@trpc/server": "catalog:",
    "discord-api-types": "^0.37.120",
    "json-schema-to-zod": "^2.7.0",
    "minimatch": "^10.2.4",
    "minio": "^8.0.6",
    "passkit-generator": "^3.5.7",
    "qrcode": "^1.5.4",
    "resend": "^3.5.0",
    "stripe": "^17.7.0",
    "superjson": "2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@forge/eslint-config": "workspace:*",
    "@forge/prettier-config": "workspace:*",
    "@forge/tsconfig": "workspace:*",
    "@types/minimatch": "^6.0.0",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@forge/prettier-config"
}
